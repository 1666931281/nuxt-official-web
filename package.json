{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "nuxt dev --dotenv .env.local",
    "build:dev": "nuxt dev --dotenv env/.env.dev",
    "build:test": "nuxt dev --dotenv env/.env.test",
    "build:prod": "nuxt build --dotenv env/.env.prod",
    "build": "npm run build:prod",
    "dev": "nuxt dev --dotenv .env.dev --host",
    "dev:prod": "nuxt dev --dotenv .env.prod --host",
    "generate:test": "nuxt generate --dotenv .env.test",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "packageManager": "pnpm@8.15.5",
  "dependencies": {
    "@nuxt/eslint": "^0.3.13",
    "@nuxtjs/proxy": "^2.1.0",
    "crypto-js": "^4.2.0",
    "eslint-config": "link:@nuxt/eslint-config",
    "postcss-px-to-viewport": "^1.1.1",
    "postcss-pxtorem": "^6.1.0",
    "scss": "^0.2.4",
    "vue": "^3.4.27",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@element-plus/nuxt": "^1.0.9",
    "@eslint/js": "^9.3.0",
    "@nuxtjs/color-mode": "^3.4.1",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@types/crypto-js": "^4.2.2",
    "@typescript-eslint/parser": "^7.11.0",
    "commitlint": "^19.3.0",
    "conventional-changelog-cli": "^5.0.0",
    "element-plus": "^2.7.3",
    "eslint": "^9.3.0",
    "eslint-plugin-vue": "^9.26.0",
    "globals": "^15.3.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "nuxt": "^3.11.2",
    "postcss-preset-env": "^9.5.14",
    "prettier": "^3.2.5",
    "sass": "^1.77.2",
    "sass-loader": "^14.2.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.10.0",
    "vite-plugin-compression": "^0.5.1",
    "vue-tsc": "^1.8.22"
  }
}